7. Напишите функцию regr.calc, которая на вход получает dataframe c двумя переменными.

Если две переменные значимо коррелируют (p - уровень значимости для коэффициента корреляции Пирсона меньше 0.05), то функция строит регрессионную модель,
где первая переменная - зависимая, вторая - независимая. Затем создает в dataframe новую переменную с назанием fit, где сохраняет предсказанные моделью значения зависимой переменной. 
В результате функция должна возвращать исходный dataframe с добавленной новой переменной fit.

Если две переменные значимо не коррелируют, то функция возвращает строчку "There is no sense in prediction"

regr.calc <- function(dataframe) {
  # Проверяем корреляцию между переменными
  cor_test <- cor.test(dataframe[,1], dataframe[,2])
  
  # Если корреляция значима (p-value меньше 0.05), строим регрессионную модель
  if(cor_test$p.value < 0.05) {
    # Строим регрессионную модель
    fit <- lm(dataframe[,1] ~ dataframe[,2], data = dataframe)
    
    # Предсказываем значения зависимой переменной
    dataframe$fit <- predict(fit)
  } else {
    # Если корреляция не значима, возвращаем сообщение об этом
    return ("There is no sense in prediction")
  }
  
  # Возвращаем dataframe с добавленной переменной fit
  return(dataframe)
}

Пример правильного решения:

regr.calc <- function(sample_data){    
	cor_result = cor.test(~sample_data[[1]] + sample_data[[2]])    
	if (cor_result$p.value < 0.05){    
		fit_model  <- lm(sample_data[[1]] ~ sample_data[[2]])    
		sample_data$fit  <- fit_model$fitted.values    
	return(sample_data)    
	} else {    
		return('There is no sense in prediction')}}

