from openpyxl import load_workbook

# Загрузка данных из файла Excel
file_path = '/content/trekking1.xlsx'
workbook = load_workbook(file_path)
sheet = workbook.active

# Получение данных из таблицы
data = []
for row in sheet.iter_rows(values_only=True):
    data.append(row)

import pandas as pd
table = pd.DataFrame(data[1:], columns = ['продукт', 'ккал', 'b', 'g', 'u'])
table = table.drop(columns=['b', 'g', 'u'])
listof = list(table.sort_values(['ккал', 'продукт'], ascending=[False, True]).продукт)
print(*listof, sep = '\n')

