# 3. На этот раз будем работать с Dogs API. Ваша задача узнать что за порода скрывается под id = 258. Чтобы выполнить запросы к этому сервису вам предварительно нужно получить токен.
host – https://api.thedogapi.com/v1/
auth – api_key
В качестве ответа укажите породу собаки, поле name.

import requests

# URL API Dogs
url = "https://api.thedogapi.com/v1/breeds/258"

# Замените 'YOUR_API_KEY' на ваш API-ключ
headers = {
    "x-api-key": "YOUR_API_KEY"
}

# Выполняем GET-запрос
response = requests.get(url, headers=headers)

# Проверяем успешность запроса
if response.status_code == 200:
    # Извлекаем данные в формате JSON
    data = response.json()

    # Проверяем, есть ли данные
    if data:
        # Выводим имя породы собаки
        print("Порода собаки с id 258:", data["name"])
    else:
        print("Нет данных о породе с указанным id.")
else:
    print("Ошибка при выполнении запроса:", response.status_code)  # Порода собаки с id 258: White Shepherd
