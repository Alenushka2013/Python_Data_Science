# 1. Есть API, которая выдает средний возраст людей по их имени. Вам нужно определить средний возраст для имени elena.
host – https://agify.io/
query param – name
Пример запроса к API – https://api.agify.io?name=michael

import requests
host = "https://api.agify.io"
try:
    r = requests.get(host, params={"name": "elena"})
    r.raise_for_status()
except requests.HTTPError as e:
    print("HTTPError:", e)
except Exception as e:
    print("Something went wrong with request:", e)
else:
    print(r.json()["age"])

import requests
url = "https://api.agify.io/"
params = {
    "name": "elena"
}
response = requests.get(url, params=params)
print(response.json()["age"])

# 2. В этот раз мы будем работать с хранилищем знаний о пиве – Punk API. Ваша задача – узнать какое пиво IPA впервые было сварено до января 2008 года.
host – https://api.punkapi.com/v2/
название пива – ipa
впервые сварено до – 01-2008
В качестве ответа укажите id пива.

import requests

# URL API Punk
url = "https://api.punkapi.com/v2/beers"

# Параметры запроса
params = {
    "beer_name": "ipa",
    "brewed_before": "01-2008"
}

# Выполняем GET-запрос
response = requests.get(url, params=params)

# Проверяем успешность запроса
if response.status_code == 200:
    # Извлекаем данные в формате JSON
    data = response.json()

    # Проверяем, есть ли данные
    if data:
        # Выводим id первого пива в списке
        print("ID первого IPA пива, сваренного до января 2008 года:", data[0]["id"])
    else:
        print("Нет данных о пиве с указанными параметрами.")
else:
    print("Ошибка при выполнении запроса:", response.status_code) # ID первого IPA пива, сваренного до января 2008 года: 192

import requests

url = "https://api.punkapi.com/v2/beers"
params = {
    "beer_name": "ipa",
    "brewed_before": "01-2008"
}

response = requests.get(url, params=params).json()
print(response[0]['id'])


